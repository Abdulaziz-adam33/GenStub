# Audit level set to high — ignores the moderate PostCSS false positive
# in Next.js's internal bundled deps (GHSA-qx2v-qp2m-jg93).
# npm audit incorrectly suggests downgrading Next.js to v9 to fix it,
# which is wrong — Next.js uses PostCSS only at build time, not in the
# browser, so this vulnerability does not affect our security surface.
# Genuine vulnerabilities (high/critical) will still surface.
audit-level=high
